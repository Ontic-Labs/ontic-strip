# ──────────────────────────────────────────────
# Ontic Strip — Environment Variables
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────
#
# Environments
# ─────────────
# Production  (main branch)   → Supabase "ontic-strip"
# Preview     (PR branches)   → Supabase "dev-ontic-strip"
# Development (vercel dev)    → Supabase "dev-ontic-strip"
#
# Vercel env vars are set per-environment via `vercel env`.
# For local dev, copy this file to .env and point at the dev project.

# ── Frontend (Vite) ──────────────────────────
# These are exposed to the browser (VITE_ prefix).
# Use your Supabase project's *anon* (publishable) key, NOT the service role key.

VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...your-anon-key

# ── Supabase Edge Functions (Deno) ───────────
# Set these as Supabase secrets: `supabase secrets set KEY=value`

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ── LLM / AI ────────────────────────────────
# OpenRouter gateway — all AI oracle functions route through this
OPENROUTER_API_KEY=sk-or-...

# ── External Services ────────────────────────
# Firecrawl for web scraping (oracle-evidence)
FIRECRAWL_API_KEY=fc-...

# Inoreader RSS integration (optional)
INOREADER_APP_ID=
INOREADER_APP_KEY=

# ── Optional Graphile Worker Scaffold (Step 1) ──
# Not used by current production flow. Reserved for gradual migration.
GRAPHILE_DATABASE_URL=postgresql://postgres:password@host:5432/postgres
GRAPHILE_CONCURRENCY=5
